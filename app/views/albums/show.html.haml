%p#notice= notice

%p
  %b Album Name:
  = @album.name

%p
  %b Owner:
  =link_to @album.owner, @album.user
  =image_tag @album.user.avatar, class: "img-polaroid"

%ul.thumbnails
  -@photos.each_slice(3) do |photo_set|
    .row-fluid.image_set
      -photo_set.each do |photo|
        = render photo

- @photo = Photo.new


%input#fileupload{:multiple => "", :name => "photo[image]", :type => "file"}

:javascript
  $('#fileupload').hide();

  $(function () {
      $('#fileupload').fileupload({
          dataType: 'json',
          url: '#{ uploader_path(@album) }',
          done: function (e, data) {


            $.each(data.result, function (index, response) {

              var photo_id = response.match(/\b\d+/)[0];
              var blah =  '<div class="controls">'+
                            '<a href="/photos/'+photo_id+
                            '" class="btn btn-sml photo-controls" style="display: none;">Show</a>'+
                          '</div>'


              var list_item = $(  '<li class="span4">'+
                                    '<a href="/photos/'+photo_id+'">'+
                                      '<img src="' + response+'" class="img-polaroid img-rounded">'+
                                    '</a>'+
                                    blah+
                                  '</li>');

              var div = "<div class='row-fluid image_set'></div>"
              var size = $('.image_set:last').children("li").size()

              if ( size == 0 || size == 3 )
                  {
                    $(div).appendTo('.thumbnails');
                    $(list_item).appendTo('.image_set:last');
                  }
              else
                  {$(list_item).appendTo('.image_set:last')}

              setMouseOver();
            });

          }
      });

  });


  $('.controls a').hide()
  setMouseOver();
  function setMouseOver(){
    $(".thumbnails li").mouseover(function() {
        $(this).find('.controls a').show();
      }).mouseout(function(){
       $(this).find('.controls a').hide();
    });
  }

= link_to 'Delete Album', @album, :confirm => 'Are you sure?', :method => :delete, class: 'btn btn-danger'

= link_to 'Edit', edit_album_path(@album), class: :btn



