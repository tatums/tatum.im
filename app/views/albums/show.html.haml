.row-fluid
  .span12
    %ul.breadcrumb
      %li
        = link_to 'Home', root_path
        = content_tag :span, '/', class: :divider
      %li
        = link_to 'Albums', albums_path
        = content_tag :span, '/', class: :divider
      %li.active
        = @album.name

.page-header
  %h1
    =image_tag @album.user.avatar, class: "img-polaroid"
    = @album.name

.row-fluid
  .span12
    %ul.thumbnails
      -@photos.each_slice(3) do |photo_set|
        .row-fluid.image_set
          -photo_set.each do |photo|
            = render photo

    - @photo = Photo.new

